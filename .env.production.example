# Frontend Production Environment Variables

# Backend API URL (update with your deployed backend URL)
VITE_API_URL=https://smarttourist-backend.onrender.com

# WebSocket URL (update with your deployed backend URL)
VITE_WS_URL=wss://smarttourist-backend.onrender.com

# App Configuration
VITE_APP_NAME=Smart Tourist Safety Platform
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_TOOLS=false

# External Services (optional)
VITE_GOOGLE_MAPS_API_KEY=
VITE_ANALYTICS_ID=
